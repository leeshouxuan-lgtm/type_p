rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 여부 확인 함수
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'leeshouxuan@gmail.com'
      );
    }

    // 로그인 여부 확인 함수
    function isLoggedIn() {
      return request.auth != null;
    }

    // 본인 여부 확인 함수
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── users 컬렉션 ──────────────────────────────────
    match /users/{uid} {
      // 본인 또는 관리자만 읽기 가능
      allow read: if isOwner(uid) || isAdmin();
      // 본인만 생성 가능
      allow create: if isOwner(uid);
      // 관리자는 전체 수정 가능
      // 본인의 경우: 프로필 미완료 상태이거나, name/className 변경이 없을 때만 허용
      allow update: if isAdmin() ||
        (isOwner(uid) && (
          (!('profileComplete' in resource.data) || resource.data.profileComplete != true) ||
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny(['name', 'className']))
        ));
      // 삭제는 관리자만 가능 (일괄 삭제 기능)
      allow delete: if isAdmin();
    }

    // ── users 하위 records 컬렉션 ──────────────────────
    match /users/{uid}/records/{recordId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update, delete: if isAdmin();
    }

    // ── users 하위 bubbleRecords 컬렉션 ───────────────
    match /users/{uid}/bubbleRecords/{recordId} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update, delete: if isAdmin();
    }

    // ── admins 컬렉션 ──────────────────────────────────
    match /admins/{uid} {
      allow read: if isAdmin();
      allow write: if false; // Firebase Console에서만 수동 관리
    }

    // ── settings 컬렉션 (사이트 설정, 랭킹 설정 등) ───
    match /settings/{doc} {
      allow read: if true;          // 비로그인 포함 모두 읽기 가능 (사이트 제목 로드)
      allow write: if isAdmin();
    }

    // ── content 컬렉션 (연습 콘텐츠) ──────────────────
    match /content/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── ranking 컬렉션 (캐시된 랭킹 결과) ─────────────
    match /ranking/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── bubbleRanking 컬렉션 (미니게임 랭킹) ──────────
    match /bubbleRanking/{uid} {
      allow read: if true;
      allow write: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
